{
  "name": "tempo-flow",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted batch management with flow visualization, second-level cron, and HTTP/Kubernetes executors",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "node scripts/set-db-provider.mjs && prisma generate",
    "db:provider": "node scripts/set-db-provider.mjs",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@tempo-flow/api",
    "build:web": "turbo run build --filter=@tempo-flow/web",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "test:e2e": "vitest run --config test/e2e/vitest.config.ts",
    "test:e2e:typecheck": "tsc -p test/e2e/tsconfig.json --noEmit",
    "dev": "turbo run dev --filter=@tempo-flow/api --filter=@tempo-flow/web",
    "dev:api": "turbo run dev --filter=@tempo-flow/api",
    "dev:web": "turbo run dev --filter=@tempo-flow/web",
    "check": "turbo run typecheck lint test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.17.0",
    "@tempo-flow/eslint-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.2",
    "bcrypt": "^6.0.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
