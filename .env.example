# --- Database -------------------------------------------------------------
# provider: postgresql (default) | mysql | sqlite
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://tempo:tempo@localhost:5432/tempo_flow?schema=public"
# MySQL example:
#   DATABASE_PROVIDER=mysql
#   DATABASE_URL="mysql://tempo:tempo@localhost:3306/tempo_flow"
# SQLite example (no external DB required):
#   DATABASE_PROVIDER=sqlite
#   DATABASE_URL="file:./dev.db"

# --- API ------------------------------------------------------------------
PORT=3000
# Comma-separated allowed origins for CORS. Unset = reflect any origin (dev).
# CORS_ORIGIN="https://app.example.com"

# --- Auth -----------------------------------------------------------------
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"
# Default admin seeded by `make seed` (or SEED_ON_START in the container).
SEED_ADMIN_EMAIL="admin@tempo-flow.local"
SEED_ADMIN_PASSWORD="admin1234"

# --- Redis / Queue --------------------------------------------------------
REDIS_URL="redis://localhost:6379"
# Run the in-process BullMQ worker (set false for API-only deployments).
WORKER_ENABLED=true
# Concurrent flow-run jobs per worker.
WORKER_CONCURRENCY=5

# --- Container entrypoint -------------------------------------------------
# Apply migrations (+ optional seed) on start. Set false on worker replicas
# so only the primary applies migrations.
RUN_MIGRATIONS=true
SEED_ON_START=false

# --- Secrets --------------------------------------------------------------
# 32-byte key (hex/base64) used to encrypt notification secrets at rest.
SETTINGS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# --- Public URLs ----------------------------------------------------------
# External base URL of the API (used for completion-callback URLs handed to
# jobs, and the OIDC redirect URI).
PUBLIC_URL="http://localhost:3000"
# Where the OIDC callback hands the user back to (the web app).
WEB_URL="http://localhost:8080"

# --- Inline scripts -------------------------------------------------------
# Script nodes run as isolated one-shot containers via the host Docker daemon.
# The compose api/worker mount /var/run/docker.sock; override the CLI path if needed.
# DOCKER_PATH="docker"

# --- Tracing (OpenTelemetry) ---------------------------------------------
# Set an OTLP/HTTP endpoint to enable distributed tracing (off when empty).
# e.g. http://jaeger:4318  (`docker compose --profile observability up jaeger`)
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="tempo-flow-api"

# --- SSO (OIDC) -----------------------------------------------------------
# Enable single sign-on by setting an issuer (off when empty). Claims are read
# from the userinfo endpoint; IdP groups map to roles via OIDC_ROLE_MAP.
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
# Defaults to ${PUBLIC_URL}/api/auth/oidc/callback
# OIDC_REDIRECT_URI=""
OIDC_SCOPES="openid profile email groups"
OIDC_GROUPS_CLAIM="groups"
# JSON map of IdP group → tempo-flow role (admin|operator|approver|viewer).
OIDC_ROLE_MAP='{"tf-admins":"admin","tf-operators":"operator"}'
# Role assigned when no group matches.
OIDC_DEFAULT_ROLE="viewer"
