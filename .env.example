# --- Database -------------------------------------------------------------
# provider: postgresql (default) | mysql | sqlite
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://tempo:tempo@localhost:5432/tempo_flow?schema=public"
# MySQL example:
#   DATABASE_PROVIDER=mysql
#   DATABASE_URL="mysql://tempo:tempo@localhost:3306/tempo_flow"
# SQLite example (no external DB required):
#   DATABASE_PROVIDER=sqlite
#   DATABASE_URL="file:./dev.db"

# --- API ------------------------------------------------------------------
PORT=3000
# Comma-separated allowed origins for CORS. Unset = reflect any origin (dev).
# CORS_ORIGIN="https://app.example.com"

# --- Auth -----------------------------------------------------------------
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"
# Default admin seeded by `make seed` (or SEED_ON_START in the container).
SEED_ADMIN_EMAIL="admin@tempo-flow.local"
SEED_ADMIN_PASSWORD="admin1234"

# --- Redis / Queue --------------------------------------------------------
REDIS_URL="redis://localhost:6379"
# Run the in-process BullMQ worker (set false for API-only deployments).
WORKER_ENABLED=true
# Concurrent flow-run jobs per worker.
WORKER_CONCURRENCY=5

# --- Container entrypoint -------------------------------------------------
# Apply migrations (+ optional seed) on start. Set false on worker replicas
# so only the primary applies migrations.
RUN_MIGRATIONS=true
SEED_ON_START=false

# --- Secrets --------------------------------------------------------------
# 32-byte key (hex/base64) used to encrypt notification secrets at rest.
SETTINGS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"
